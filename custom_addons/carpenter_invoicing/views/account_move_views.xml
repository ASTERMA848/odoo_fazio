<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Los créditos del Carpintero (Padre) ahora se gestionan de forma nativa desde el widget de Odoo de Saldos Pendientes en la parte inferior -->

    <!-- Corregir la impresión del nombre del cliente en la factura para que muestre el Hijo en vez del Padre (Carpintero) -->
    <template id="report_invoice_document_carpenter" inherit_id="l10n_ar.report_invoice_document">
        <xpath expr="//span[@t-field='o.partner_id.commercial_partner_id.name']" position="replace">
            <span t-field="o.partner_id.name"/>
        </xpath>
    </template>

    <!-- Agregar columna 'Pago Centralizado' en el listado de facturas -->
    <record id="view_invoice_tree_carpenter" model="ir.ui.view">
        <field name="name">account.invoice.tree.carpenter.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='status_in_payment']" position="before">
                <field name="is_paid_with_parent_credit" string="Pago Centralizado" optional="show" widget="boolean" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Agregar filtro 'Pago por Centralizador' en la barra de búsqueda de facturas -->
    <record id="view_account_invoice_filter_carpenter" model="ir.ui.view">
        <field name="name">account.invoice.filter.carpenter.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='myinvoices']" position="before">
                <filter string="Pago por Centralizador" name="paid_with_parent_credit" domain="[('is_paid_with_parent_credit', '=', True)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <!-- Agregar insignia 'Pago por Centralizador' en la cabecera del formulario de la factura -->
    <record id="view_move_form_carpenter" model="ir.ui.view">
        <field name="name">account.move.form.carpenter.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="inside">
                <div class="mt-2" invisible="not is_paid_with_parent_credit">
                    <span class="badge rounded-pill text-bg-success" style="font-size: 0.85rem; padding: 0.4em 0.8em; display: inline-flex; align-items: center; gap: 4px;">
                        <i class="fa fa-check-circle"/> Pago por Centralizador
                    </span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
